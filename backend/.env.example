# Copy this file to .env and fill in the values.
# For local development without Docker, DATABASE_URL can be left empty — SQLite is used automatically.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
# Leave empty to use SQLite (local dev without Docker)
DATABASE_URL=postgres://swisschess:swisschess@localhost:5432/swisschess

# CORS / frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Django superuser (created automatically on first `manage.py createsuperuser --noinput`)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=changeme
